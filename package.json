{
  "name": "aizu",
  "version": "0.0.1",
  "private": true,
  "description": "Open source prompt management platform for teams",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./packages/*\" dev",
    "dev:frontend": "pnpm --filter @aizu/frontend dev",
    "dev:backend": "pnpm --filter @aizu/backend dev",
    "build": "pnpm --filter \"./packages/*\" build",
    "build:frontend": "pnpm --filter @aizu/frontend build",
    "build:backend": "pnpm --filter @aizu/backend build",
    "typecheck": "pnpm --filter @aizu/shared build && pnpm --filter @aizu/backend prisma:generate && pnpm --filter \"./packages/*\" typecheck",
    "check": "pnpm typecheck && pnpm build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm --filter \"./packages/*\" clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
